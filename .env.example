# LLM Provider — choose one: openai | anthropic | google | openrouter
LLM_PROVIDER=openai

# LLM Model — provider-specific model name
# For OpenRouter, use provider-prefixed names like: anthropic/claude-sonnet-4-20250514
LLM_MODEL=gpt-4o

# API Keys — provide the key for your chosen provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Browser automation
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# Retry / timeouts
LLM_TIMEOUT=120000
LLM_MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# Logging
LOG_LEVEL=INFO
