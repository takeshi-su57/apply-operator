# LLM Provider — choose one: openai | anthropic | google
LLM_PROVIDER=openai

# LLM Model — provider-specific model name
LLM_MODEL=gpt-4o

# API Keys — provide the key for your chosen provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Browser automation
BROWSER_HEADLESS=true

# Logging
LOG_LEVEL=INFO
